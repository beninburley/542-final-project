# ─────────────────────────────────────────────────────────────────────────────
# Steam Lens — Environment Variables
# Copy this file to .env and fill in values as needed.
# Never commit your real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Steam Web API Key
# Required ONLY for the authenticated profile search feature.
# Obtain one at: https://steamcommunity.com/dev/apikey
# Leave blank to use the app in public-only mode.
VITE_STEAM_API_KEY=

# ─── Production CORS proxy (GitHub Pages / static hosting) ───────────────────
# In development the Vite dev server proxies Steam API calls automatically.
# For production builds on GitHub Pages you must route through a CORS proxy.
#
# Set VITE_USE_CORS_PROXY=true and supply a proxy base URL.
# Example free proxy: https://corsproxy.io/?
# Example self-hosted: https://your-worker.your-account.workers.dev/?
#
# WARNING: CORS proxies expose all request URLs (including any API key).
# Consider a server-side proxy for any real deployment.
VITE_USE_CORS_PROXY=false
VITE_CORS_PROXY_URL=https://corsproxy.io/?
